%%{init: {"theme": "base", "themeVariables": {"fontSize":"12px","primaryColor":"#4A90D9","lineColor":"#666","fontFamily":"Arial"}, "flowchart": {"curve":"basis","nodeSpacing":25,"rankSpacing":35}}}%%

flowchart TB

    %% ═══════════════════════════════════
    %% FRONTEND
    %% ═══════════════════════════════════
    subgraph FE["🖥️ 前端 Frontend (Vue 3 + Element Plus)"]
        direction LR
        subgraph FE_UP["📤 上传区"]
            U1["步骤1: 基本信息表单\n项目名/地点/工期/投资\n自动生成facts.json"]
            U2["步骤2: 分区面积填写\n建构筑物/道路/绿化/临时\n前端校验合计=总面积"]
            U3["步骤3: 文件上传\n必填: 已列措施CSV\n可选: CAD/GIS/PDF/图集"]
        end
        subgraph FE_PG["⏳ 进度看板"]
            PG1["实时进度条\n17步流水线百分比"]
            PG2["章节状态卡片\nCh1~8各章当前状态"]
            PG3["日志流\nSSE实时推送"]
        end
        subgraph FE_DL["📥 交付区"]
            DL1["报告摘要卡片\n总投资/流失量/达标/审计评分"]
            DL2["下载按钮\n报告书.docx\n措施图包.zip\n审计日志.json"]
        end
        U1 --> U2 --> U3
    end

    %% ═══════════════════════════════════
    %% BACKEND API
    %% ═══════════════════════════════════
    subgraph API["🔌 后端API FastAPI (双端口)"]
        direction LR
        EP1[":8080 用户端\npipelines/config/vision"]
        EP2[":8081 管理端\nknowledge/settings"]
        EP3["SSE进度推送\n/api/pipelines/id/events"]
        EP4["SQLite server.db\n运行记录+日志"]
    end

    %% ═══════════════════════════════════
    %% CLI MODE
    %% ═══════════════════════════════════
    CLI["🖥️ CLI 模式\npython autodl_start.py --cli\npython scripts/run.py -v\n直接执行17步Pipeline"]

    %% ═══════════════════════════════════
    %% INPUT LAYER
    %% ═══════════════════════════════════
    subgraph L0["📥 输入层"]
        direction LR
        subgraph L0U["👤 用户输入"]
            F1["facts_v2.json\n概况+分区+工期+目标"]
            F2["measures_v2.csv\n已列措施+单价+合价"]
        end
        subgraph L0S["🏭 系统内置"]
            F3["soil_map.json"]
            F4["price_v2.csv\nfee_rate.json"]
            F5["legal_refs.json"]
            F6["template.docx"]
            F10["范文语料库\nChromaDB持久化\n(chromadb/)"]
            F11["measure_library.json\n35种标准措施"]
            F12["measure_symbols.py\n措施符号/样式/断面模板"]
        end
        subgraph L0O["📎 可选"]
            F7["CAD .dwg/.dxf"]
            F8["GIS .shp/.geojson"]
            F9["PDF 附件"]
            F13["标准图集\ndata/atlas/ (20文件)\nPNG/JPG/PDF/DWG"]
        end
    end

    %% ═══════════════════════════════════
    %% SPATIAL ANALYSIS LAYER
    %% ═══════════════════════════════════
    subgraph L1["⚙️ 空间分析层 (Step 1-3)"]
        direction TB

        subgraph L1_PRE["📦 基础预处理"]
            direction LR
            P1["📐 CAD转PNG\nezdxf DXF渲染\nODA DWG转换"]
            P2{"有GIS?"}
            P2 -->|Yes| P3["geopandas\n读取SHP/GeoJSON\n→ GeoDataFrame"]
            P2 -->|No| P4["直接用facts.zones\n矩形近似布局"]
            P5["📚 RAG补充\n查询范文库"]
        end

        subgraph L1_VL["👁️ VL Agent 空间分析 (Qwen2.5-VL-72B)"]
            direction LR
            VL1["CAD图纸分析\n建筑位置/道路走向\n场地边界/高程信息"]
            VL2["空间布局JSON\nbuildings[]/roads[]\nzones[]/slopes[]\ndrainage_direction"]
        end

        subgraph L1_ATLAS["📖 图集RAG索引 (atlas_rag.py)"]
            direction LR
            AR1["VL分析图集图片\n提取绘图规范\n图例/标注/配色/比例"]
            AR2["ChromaDB存储\natlas_db/\n按措施类型检索"]
        end

        subgraph L1_MERGE["🔗 空间布局合并"]
            SM1["spatial_analyzer\n综合: VL空间+GIS精确\n→ ETL.spatial_layout\n→ ETL.gis_gdf"]
        end

        L1_PRE --> L1_VL
        L1_VL --> L1_MERGE
        P3 --> L1_MERGE
    end

    %% ═══════════════════════════════════
    %% GLOBAL STATE
    %% ═══════════════════════════════════
    subgraph L2["🧠 全局状态机 GlobalState (7分区)"]
        direction LR
        S1["Static\nmeta,soil,price\nfee,legal\nmeasure_lib\nmeasures_existing"]
        S2["ETL\nzones,rag_ready\nsite_desc\nspatial_layout\ngis_gdf\nmeasure_layout"]
        S3["Calc\nearthwork\nerosion_df\ncost_summary\nbenefit"]
        S4["TplCtx\n229+标签dict\n含措施图占位标签"]
        S5["Draft\nchapters\nid→text"]
        S6["Flags\nretry_count\nfailed_list\naudit_score\naudit_log"]
        S7["Measures\nfull_measures_list\n已有+新增合并\n含空间布置字段"]
    end

    %% ═══════════════════════════════════════════════════
    %% PROCESSING LAYER
    %% ═══════════════════════════════════════════════════
    subgraph PROC["🔄 处理层 Processing Layer (Step 4-17)"]

        %% ─── COMPILATION CLUSTER ───
        subgraph COMP["📝 编制集群 Compilation Cluster"]
            direction TB

            subgraph CALC_P1["🧮 计算Phase1: 基础数据 (Step 4-5)"]
                direction LR
                C1["🏗️ 土方师\n挖-剥+覆=净挖\n净挖-填=余方"]
                C2["🌊 预测师\n3时段切分\nRUSLE查表\n分区x时段矩阵"]
            end

            subgraph PLANNER["🤖 措施规划师 Agent (Step 6)"]
                direction TB
                PL_AGENT["Qwen2.5-72B-Instruct\n角色: 水保措施设计专家\n输入: 分区+侵蚀+已有措施\n+空间布局+图集规范\n决策: 措施+数量+空间布置"]

                subgraph PL_TOOLS["🧰 规划工具箱 (6个工具)"]
                    direction LR
                    PLT1["measure_library\n标准措施库查询\n按分区类型匹配"]
                    PLT2["quantity_estimator\n工程量估算\n面积x系数"]
                    PLT3["regulation_checker\n地方标准合规\n江苏省水保条例"]
                    PLT4["rag_exemplar\n范文措施方案\n相似项目参考"]
                    PLT5["spatial_context\n空间布局查询\n建筑/道路/坡度/排水"]
                    PLT6["atlas_reference\n图集绘图规范\n符号/标注/布置要求"]
                end

                PL_OUT["输出: 完整措施清单\n每条含: 名称/分区/类型\n数量/单位/功能\n空间布置: position\ncoverage/direction/note"]

                PL_AGENT --> PL_TOOLS
                PL_TOOLS --> PL_OUT
            end

            subgraph CALC_P2["🧮 计算Phase2: 基于措施 (Step 7-8)"]
                direction LR
                C3["💰 造价师\n6层费率叠加\n新增/已有拆分\n独立费+补偿"]
                C4["📊 效益分析\n六指标实现\nvs防治目标"]
            end

            ASM["🔧 状态装配器 (Step 9)\nCalc结果映射229模板标签"]

            subgraph WRITER["🤖 撰稿智能体 Agent (Step 10)"]
                direction TB
                WR_AGENT["Qwen2.5-72B-Instruct\n角色: 水保方案撰稿专家\n逐章串行生成\nCh2→3→4→5→6→7→8→Ch1"]

                subgraph WR_TOOLS["🧰 撰稿工具箱 (4个工具)"]
                    direction LR
                    WRT1["rag_search\n按章节动态构造query\n检索范文对应段落"]
                    WRT2["calc_lookup\n查询State中任意\n计算结果和数值"]
                    WRT3["self_checker\n写完一章后自查\n数字引用是否正确"]
                    WRT4["prev_chapter\n获取前序章节摘要\n保持上下文连贯"]
                end

                WR_AGENT --> WR_TOOLS
            end

            subgraph COMP_BINDERY["🖨️ 制图与渲染组 (Step 11-13)"]
                direction TB
                B1["📊 数据图表 (Step 11)\nerosion/pie/bar/zone\nmatplotlib → 4张PNG"]

                subgraph DRAWING["🤖 绘图智能体 Agent (Step 12)"]
                    direction TB
                    DR_AGENT["Qwen2.5-72B-Instruct\n角色: 措施图绘制工程师\nSL73_6-2015制图标准\n编写matplotlib代码\nmax_turns=8"]

                    subgraph DR_TOOLS["🧰 绘图工具箱 (4个工具)"]
                        direction LR
                        DRT1["get_project_data\n分区/措施/空间布局"]
                        DRT2["get_style_reference\nSL73_6-2015规范\n+内置样式"]
                        DRT3["execute_drawing_code\n沙箱exec matplotlib\n受限builtins+白名单\n+6层自动代码修正"]
                        DRT4["verify_image\nVL模型评分≥70通过\nfallback: >10KB通过"]
                    end

                    DR_FALLBACK{"产出≥2张?"}
                    DR_FALLBACK -->|No| MM_FALLBACK["MeasureMapRenderer\n确定性Python渲染\n(measure_map.py)"]

                    DR_AGENT --> DR_TOOLS
                    DR_TOOLS --> DR_FALLBACK
                end

                B2["合并上下文 (Step 13)\ntpl_ctx+chapters\n+charts+措施图"]
                B3["渲染引擎 (3阶段)\nPhase1: docxtpl变量替换\nPhase2: python-docx循环表格\nPhase3: 措施图后插入"]
                B4["完整性检查\n无残留标签 12表非空"]
                B1 --> DRAWING --> B2 --> B3 --> B4
            end

            CALC_P1 --> PLANNER
            PLANNER --> CALC_P2
            CALC_P2 --> ASM
            ASM --> WRITER
            WRITER --> COMP_BINDERY
        end

        %% ─── AUDIT CLUSTER ───
        subgraph AUDIT["🔍 审计集群 Audit Cluster (Step 14-15)"]
            direction TB

            AUDIT_AGENT["🤖 审计智能体 Qwen2.5-72B-Instruct\n角色: 水保方案审查专家\n输入: 全量State+Draft+TplCtx\n输出: 审计报告+评分+决策"]

            subgraph AUDIT_TOOLS["🧰 审计工具箱 (3个工具)"]
                direction LR
                AT1["numeric_validator\nPython硬逻辑\n投资/面积/流失\n数值一致性"]
                AT2["text_validator\nLLM调用\n摘要数字匹配\n章节间矛盾"]
                AT3["rag_comparator\n范文对比\n结构合规性\n术语准确性"]
            end

            subgraph AUDIT_OUTPUT["📋 审计输出"]
                direction LR
                AO1["审计报告\n逐章评分\n问题清单\n修改建议"]
                AO2["综合评分\n0到100分"]
            end

            subgraph AUDIT_R["🔄 章节级重试"]
                R1{"评分>=80?"}
                R2["生成精准feedback:\nchapter_id+问题原因\n+修改指令"]
                R3{"retry<3?"}
                R4["仅重新生成\n失败章节\n附带修改指令"]
                R5["强制通过\n写入审计日志\n标记需人工复核"]
                R1 -->|60~79| R2
                R1 -->|<60| R5
                R2 --> R3
                R3 -->|Yes| R4
                R3 -->|No| R5
            end

            AUDIT_AGENT --> AUDIT_TOOLS
            AUDIT_TOOLS --> AUDIT_OUTPUT
            AUDIT_OUTPUT --> R1
        end

        %% inter-cluster
        COMP --> AUDIT
        R4 -->|带修改指令| WR_AGENT

    end

    %% ═══════════════════════════════════
    %% STORAGE & DELIVERY (Step 16-17)
    %% ═══════════════════════════════════
    subgraph L7["📦 存储与交付 (Step 16-17)"]
        direction LR
        ST1["本地文件系统\ndata/output/\ndocx+png+json"]
        ST2["SQLite server.db\n运行记录+日志"]
        ST3["CLI: 直接输出\nWeb: 下载链接"]
    end

    FINAL(["📄 报告书.docx + 措施图.png×N + 审计日志.json"])

    %% ═══════════════════════════════════
    %% GPU ALLOCATION
    %% ═══════════════════════════════════
    GPU["🎮 GPU分配 4×A800-80G\n─────────────────────\nvLLM实例1 (GPU 0-1, TP=2)\nQwen2.5-72B-Instruct-GPTQ-Int8\nport 8000 | 规划/撰稿/审计/绘图\n─────────────────────\nvLLM实例2 (GPU 2-3, TP=2)\nQwen2.5-VL-72B-Instruct-GPTQ-Int8\nport 8001 | 空间分析/图集索引/图片验证"]

    %% ═══════════════════════════════════
    %% AUTODL DEPLOYMENT
    %% ═══════════════════════════════════
    DEPLOY["🚀 AutoDL 一键部署\npython autodl_start.py\n─────────────────────\n自动: ModelScope下载模型\n自动: 清华镜像安装依赖\n自动: HF_ENDPOINT镜像\n自动: embedding预下载\n自动: 中文字体安装\n自动: 双vLLM实例启动"]

    %% ═══════════════════════════════════
    %% ALL CONNECTIONS
    %% ═══════════════════════════════════

    %% Frontend/CLI to API
    U3 --> EP1
    CLI --> L0
    EP1 --> L0

    %% API/CLI progress
    EP3 -.- PG1
    EP3 -.- PG2
    EP4 -.- DL2

    %% Input to Spatial Analysis
    F7 -.-> P1
    F8 -.-> P2
    F9 -.-> P5
    F13 -.-> AR1
    P1 --> VL1

    %% Input to State
    L0U ==> S1
    L0S ==> S1
    F10 --> S2
    F11 --> S1
    F12 --> DRAWING

    %% Spatial Analysis to State
    P3 --> SM1
    P4 --> SM1
    VL2 --> SM1
    SM1 --> S2
    AR2 --> PLT6
    P5 --> S2

    %% Atlas indexing
    AR1 --> AR2

    %% State to Compilation: Phase1
    S1 --> CALC_P1
    S2 --> CALC_P1
    CALC_P1 --> S3

    %% State to Planner (with spatial)
    S1 --> PL_AGENT
    S2 --> PL_AGENT
    S3 --> PL_AGENT
    PL_OUT --> S7

    %% Spatial layout feeds planner tools
    S2 -.->|spatial_layout| PLT5
    AR2 -.->|atlas_conventions| PLT6

    %% State to Compilation: Phase2
    S7 --> CALC_P2
    S1 --> CALC_P2
    CALC_P2 --> S3

    %% Calc to Assembler
    S1 --> ASM
    S3 --> ASM
    S7 --> ASM
    ASM --> S4

    %% State to Writer Agent
    S4 --> WR_AGENT
    S2 --> WR_AGENT
    WR_TOOLS --> S5

    %% State to Drawing Agent
    S2 -.->|spatial_layout+gis_gdf| DR_AGENT
    S7 -.->|measures+空间布置| DR_AGENT
    AR2 -.->|atlas制图规范| DRT2

    %% VL for verification
    DRT4 -.->|VL评分| GPU

    %% State to Render
    S4 --> B2
    S5 --> B2
    F6 --> B3

    %% Compilation to Audit
    S3 --> AUDIT_AGENT
    S4 --> AUDIT_AGENT
    S5 --> AUDIT_AGENT
    S2 --> AUDIT_AGENT

    %% Audit exit
    R1 -->|>=80通过| L7
    R5 --> L7
    R5 --> S6

    %% Storage to Frontend
    L7 --> FINAL
    ST2 -.- EP3
    FINAL -.- DL1
    S6 -.- DL1

    %% Progress feedback
    COMP -.->|编制进度| EP3
    AUDIT -.->|审计进度| EP3

    %% GPU note connection
    GPU -..- PROC
    GPU -..- L1
    DEPLOY -..- GPU

    %% ═══════════════════════════════════
    %% STYLES
    %% ═══════════════════════════════════
    classDef fe fill:#E8EAF6,stroke:#3949AB,color:#1A237E
    classDef api fill:#FFF3E0,stroke:#E65100,color:#BF360C
    classDef cli fill:#E0F2F1,stroke:#00695C,color:#004D40,stroke-width:2px
    classDef userIn fill:#E3F2FD,stroke:#1565C0,color:#0D47A1
    classDef sysIn fill:#ECEFF1,stroke:#455A64,color:#263238
    classDef opt fill:#F5F5F5,stroke:#9E9E9E,color:#616161,stroke-dasharray:5 5
    classDef pre fill:#FFF8E1,stroke:#F9A825,color:#F57F17
    classDef st fill:#F3E5F5,stroke:#6A1B9A,color:#4A148C
    classDef cal fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20
    classDef asm fill:#FFF9C4,stroke:#F9A825,color:#F57F17,stroke-width:3px
    classDef agent fill:#FFCCBC,stroke:#BF360C,color:#BF360C,stroke-width:3px
    classDef tools fill:#FCE4EC,stroke:#C62828,color:#B71C1C
    classDef wr fill:#E0F2F1,stroke:#00695C,color:#004D40
    classDef retry fill:#FFF9C4,stroke:#F9A825,color:#F57F17,stroke-width:3px
    classDef render fill:#E0F7FA,stroke:#00838F,color:#006064
    classDef store fill:#F1F8E9,stroke:#558B2F,color:#33691E
    classDef final fill:#C8E6C9,stroke:#2E7D32,color:#1B5E20,stroke-width:3px
    classDef gpu fill:#E1BEE7,stroke:#7B1FA2,color:#4A148C,stroke-dasharray:5 5
    classDef spatial fill:#E8EAF6,stroke:#283593,color:#1A237E,stroke-width:2px
    classDef vision fill:#FFF3E0,stroke:#E65100,color:#BF360C,stroke-width:2px
    classDef atlas fill:#F3E5F5,stroke:#7B1FA2,color:#4A148C,stroke-width:2px
    classDef mmap fill:#E3F2FD,stroke:#0D47A1,color:#01579B,stroke-width:3px
    classDef deploy fill:#DCEDC8,stroke:#33691E,color:#1B5E20,stroke-width:3px

    class U1,U2,U3,PG1,PG2,PG3,DL1,DL2 fe
    class EP1,EP2,EP3,EP4 api
    class CLI cli
    class F1,F2 userIn
    class F3,F4,F5,F6,F10,F11,F12 sysIn
    class F7,F8,F9,F13 opt
    class P1,P3,P4,P5 pre
    class S1,S2,S3,S5,S6,S7 st
    class S4 asm
    class C1,C2 cal
    class C3,C4 cal
    class ASM asm
    class PL_AGENT,WR_AGENT,AUDIT_AGENT,DR_AGENT agent
    class PLT1,PLT2,PLT3,PLT4 tools
    class PLT5,PLT6 spatial
    class WRT1,WRT2,WRT3,WRT4 tools
    class DRT1,DRT2,DRT3,DRT4 tools
    class AT1,AT2,AT3 tools
    class PL_OUT,AO1,AO2 tools
    class R2,R4 retry
    class B1,B2,B3,B4 render
    class VL1,VL2 vision
    class AR1,AR2 atlas
    class SM1 spatial
    class DR_FALLBACK,MM_FALLBACK mmap
    class ST1,ST2,ST3 store
    class FINAL final
    class GPU gpu
    class DEPLOY deploy
