{
  "description": "水土保持工程投资费率配置（江苏省）。6层费率叠加 + 独立费用 + 预备费 + 补偿费。",
  "version": "2024-01",
  "province": "江苏省",

  "fee_layers": {
    "L1_其他直接费": {
      "base": "直接费",
      "rates": { "工程措施": 0.023, "植物措施": 0.023, "临时措施": 0.023 },
      "note": "冬雨季施工增加费、夜间施工增加费等"
    },
    "L2_现场经费": {
      "base": "直接费",
      "rates": { "工程措施": 0.050, "植物措施": 0.040, "临时措施": 0.040 },
      "note": "临时设施费、工具用具使用费、现场管理人员工资等"
    },
    "L3_间接费": {
      "base": "直接工程费",
      "note_direct_eng": "直接工程费 = 直接费 + L1 + L2",
      "rates": { "工程措施": 0.055, "植物措施": 0.033, "临时措施": 0.033 },
      "note": "企业管理费"
    },
    "L4_企业利润": {
      "base": "直接工程费+间接费",
      "rates": { "工程措施": 0.070, "植物措施": 0.050, "临时措施": 0.050 },
      "note": "施工企业合法利润"
    },
    "L5_税金": {
      "base": "直接工程费+间接费+利润",
      "rates": { "工程措施": 0.090, "植物措施": 0.090, "临时措施": 0.090 },
      "note": "增值税及附加"
    }
  },

  "independent_fees": {
    "建设管理费": {
      "base": "建安工程费",
      "rate": 0.020,
      "note": "建设单位管理费"
    },
    "工程建设监理费": {
      "base": "建安工程费",
      "rate": 0.030,
      "note": "水保工程监理"
    },
    "科研勘测设计费": {
      "method": "lookup_by_investment",
      "lookup_table": [
        { "max_investment_万元": 100, "fee_万元": 5.0 },
        { "max_investment_万元": 300, "fee_万元": 10.0 },
        { "max_investment_万元": 500, "fee_万元": 15.0 },
        { "max_investment_万元": 1000, "fee_万元": 22.0 },
        { "max_investment_万元": 999999, "fee_万元": 30.0 }
      ],
      "note": "按方案新增投资规模查表"
    },
    "水土保持监测费": {
      "method": "lookup_by_area",
      "lookup_table": [
        { "max_area_hm2": 5, "fee_万元": 8.0 },
        { "max_area_hm2": 20, "fee_万元": 12.0 },
        { "max_area_hm2": 50, "fee_万元": 18.0 },
        { "max_area_hm2": 200, "fee_万元": 28.0 },
        { "max_area_hm2": 999999, "fee_万元": 40.0 }
      ],
      "note": "按项目扰动面积查表"
    },
    "水土保持设施验收费": {
      "method": "fixed",
      "fee_万元": 5.0,
      "note": "技术评估费，市级审批项目一般5万元"
    }
  },

  "reserve_fee": {
    "base": "一至四部分合计",
    "rate": 0.06,
    "note": "基本预备费，费率6%"
  },

  "compensation_fee": {
    "method": "area_based",
    "unit": "元/m²",
    "rates_by_city": {
      "南京市": 1.5,
      "无锡市": 1.2,
      "徐州市": 0.8,
      "常州市": 1.2,
      "苏州市": 1.5,
      "南通市": 1.0,
      "连云港市": 0.8,
      "淮安市": 0.8,
      "盐城市": 1.0,
      "扬州市": 1.0,
      "镇江市": 1.2,
      "泰州市": 0.8,
      "宿迁市": 0.8
    },
    "default": 1.0,
    "note": "水土保持补偿费 = 占地面积(m²) × 地区单价"
  },

  "total_structure": {
    "第一部分_工程措施费": "各工程措施经L1~L5叠加后的建安费合计",
    "第二部分_植物措施费": "各植物措施经L1~L5叠加后的建安费合计",
    "第三部分_临时措施费": "各临时措施经L1~L5叠加后的建安费合计",
    "第四部分_独立费用":   "建设管理费+监理费+科研勘测设计费+监测费+验收费",
    "一至四部分小计":      "第一+第二+第三+第四",
    "第五部分_基本预备费":  "一至四部分小计 × 6%",
    "第六部分_水保补偿费":  "占地面积 × 地区单价",
    "水保总投资":          "一至六部分合计"
  }
}
